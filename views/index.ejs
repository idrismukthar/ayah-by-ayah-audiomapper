<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Athar | Quran Memorization</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #c5a059;
            --bg: #050505;
            --card: #121212;
            --text-main: #e0e0e0;
            --text-dim: #666;
        }

        body {
            background-color: var(--bg);
            color: var(--text-main);
            font-family: 'Amiri', serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        header {
            width: 100%;
            padding: 60px 0;
            text-align: center;
            background: linear-gradient(to bottom, #111, #050505);
            border-bottom: 1px solid rgba(197, 160, 89, 0.2);
        }

        header h1 {
            font-size: 3.5rem;
            margin: 0;
            color: var(--gold);
            text-shadow: 0 0 30px rgba(197, 160, 89, 0.2);
        }

        header p {
            color: var(--text-dim);
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 0.9rem;
            margin-top: 10px;
        }

        .container {
            max-width: 1000px;
            width: 90%;
            margin: 50px 0;
        }

        .surah-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .surah-card {
            background: var(--card);
            border: 1px solid #222;
            border-radius: 15px;
            padding: 25px;
            text-decoration: none;
            color: white;
            display: flex;
            align-items: center;
            gap: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .surah-card:hover {
            border-color: var(--gold);
            background: #1a1a1a;
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .surah-num {
            font-size: 1.5rem;
            color: var(--gold);
            opacity: 0.5;
            font-weight: bold;
            min-width: 40px;
        }

        .surah-info h3 {
            margin: 0;
            font-size: 1.4rem;
            color: var(--text-main);
        }

        .surah-info p {
            margin: 5px 0 0;
            color: var(--text-dim);
            font-size: 0.85rem;
            text-transform: capitalize;
        }

        .btn-mapper {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--gold);
            color: black;
            padding: 15px 25px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: bold;
            box-shadow: 0 5px 20px rgba(0,0,0,0.5);
            transition: 0.2s;
            z-index: 100;
        }

        .btn-mapper:hover {
            transform: scale(1.05);
            background: #d4b47a;
        }
    </style>
</head>
<body>

<header>
    <h1>أَثَر</h1>
    <p>The Immersive Quran Memorization Experience</p>
</header>

<div class="container">
    <div class="surah-grid">
        <% surahs.forEach(surah => { %>
            <a href="/surah/<%= surah.id %>" class="surah-card">
                <div class="surah-num"><%= surah.id %></div>
                <div class="surah-info">
                    <h3><%= surah.name %></h3>
                    <p>Ready for Hifz</p>
                </div>
            </a>
        <% }) %>
    </div>
</div>

<a href="/mapper" class="btn-mapper">Open Audio Mapper 🛠️</a>

</body>
</html>
